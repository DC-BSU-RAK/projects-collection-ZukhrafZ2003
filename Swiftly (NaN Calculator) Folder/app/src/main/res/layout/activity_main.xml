<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SWIFTLY"
            android:textColor="@color/purple_mid"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnInfo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="@string/info_btn"
            android:textColor="@color/purple_mid"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#1e1e35"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="130dp"
        android:orientation="vertical"
        android:background="@color/bg_display"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="your equation"
            android:textColor="@color/text_muted"
            android:textSize="9sp"/>

        <TextView
            android:id="@+id/tvEquation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textSize="26sp"
            android:textColor="#ffffff"
            android:gravity="center_vertical"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="italic"
            android:textColor="@color/purple_light"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

    <GridLayout
        android:id="@+id/eraGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="3"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="BACK ⌫"
            android:textSize="11sp"
            android:textColor="@color/purple_mid"
            android:backgroundTint="@color/bg_card"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="CLEAR ✕"
            android:textSize="11sp"
            android:textColor="@color/pink_accent"
            android:backgroundTint="#1a0a1a"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="56dp"
            android:text="✦ DECODE ERA"
            android:textSize="11sp"
            android:textColor="@color/purple_light"
            android:backgroundTint="#2a0a3a"
            android:layout_margin="4dp"/>

    </LinearLayout>

</LinearLayout>